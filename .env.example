# ========================================================
# Captura de e-mails (provider plugável — escolher 1)
# ========================================================
#
# LEAD_PROVIDER = "none" | "brevo" | "mailchimp" | "resend" | "console"
#   - none:     desliga captura (formulário mostra "em breve")
#   - console:  apenas loga no servidor (para testar antes de integrar)
#   - brevo:    Brevo (antigo SendinBlue) — API key em BREVO_API_KEY
#   - mailchimp: Mailchimp — MAILCHIMP_API_KEY + MAILCHIMP_LIST_ID + MAILCHIMP_DC
#   - resend:   Resend — RESEND_API_KEY (envio simples de PDF)
#
LEAD_PROVIDER=console

# Brevo
BREVO_API_KEY=
BREVO_LIST_ID=

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_DC=

# Resend (envio direto de material)
RESEND_API_KEY=
RESEND_FROM="Juliana Maia Nutri APLV <contato@julianamaianutriaplv.com.br>"
